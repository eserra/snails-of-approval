generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  role         String   @default("editor") // admin, editor, viewer
  createdAt    DateTime @default(now()) @map("created_at")

  snails         Snail[]
  assignedSnails Snail[] @relation("assignedSnails")
  authoredNotes  Note[]  @relation("authoredNotes")

  @@map("users")
}

model Chapter {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  name      String
  state     String
  createdAt DateTime @default(now()) @map("created_at")

  snails Snail[]

  @@map("chapters")
}

model Category {
  id        Int        @id @default(autoincrement())
  slug      String     @unique
  name      String
  parentId  Int?       @map("parent_id")
  parent    Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryHierarchy")
  createdAt DateTime   @default(now()) @map("created_at")

  snails Snail[]

  @@map("categories")
}

model Snail {
  id           Int      @id @default(autoincrement())
  slug         String   @unique
  name         String
  yearAwarded  Int?     @map("year_awarded")
  description  String?  @db.Text
  address      String?
  latitude     Decimal? @db.Decimal(10, 7)
  longitude    Decimal? @db.Decimal(10, 7)
  email        String?
  phone        String?
  website      String?
  facebookUrl  String?  @map("facebook_url")
  instagramUrl String?  @map("instagram_url")
  photoUrl     String?  @map("photo_url")
  status       String   @default("draft") // draft, published
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // CRM Pipeline
  track          String  @default("lead") @map("track")
  stage          String? @map("stage")
  formerAwardee  Boolean @default(false) @map("former_awardee")
  renewalDueYear Int?    @map("renewal_due_year")
  businessStatus String? @map("business_status")
  source         String?
  blockedReason  String? @map("blocked_reason")

  // Contact at the establishment
  contactName String? @map("contact_name")

  // Geography
  borough String?
  zip     String?

  // SFUSA national mapping
  onSfusaMap    Boolean @default(false) @map("on_sfusa_map")
  sfusaCategory String? @map("sfusa_category")
  sfusaSubtype  String? @map("sfusa_subtype")

  // Transitional (to be removed once SFUSA categories fully adopted)
  establishmentType String? @map("establishment_type")

  // CRM tracking
  assigneeId        Int?      @map("assignee_id")
  lastTouchDate     DateTime? @map("last_touch_date")
  welcomeLetterSent Boolean   @default(false) @map("welcome_letter_sent")
  stickersDelivered Boolean   @default(false) @map("stickers_delivered")
  diversityTags     String?   @map("diversity_tags")

  // Relations
  categoryId  Int?      @map("category_id")
  category    Category? @relation(fields: [categoryId], references: [id])
  chapterId   Int       @map("chapter_id")
  chapter     Chapter   @relation(fields: [chapterId], references: [id])
  createdById Int?      @map("created_by_id")
  createdBy   User?     @relation(fields: [createdById], references: [id])
  assignee    User?     @relation("assignedSnails", fields: [assigneeId], references: [id])
  notes       Note[]

  @@map("snails")
}

model Note {
  id        Int      @id @default(autoincrement())
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  snailId  Int   @map("snail_id")
  snail    Snail @relation(fields: [snailId], references: [id], onDelete: Cascade)
  authorId Int   @map("author_id")
  author   User  @relation("authoredNotes", fields: [authorId], references: [id])

  @@map("notes")
}
